# Сервер
PORT=3000
NODE_ENV=development

# Дерекқор
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Міндетті: JWT (жоқ болса логин/тіркелу 500 қате береді)
JWT_SECRET=өзіңіздің-құпия-кілтіңіз-мына-жолды-өзгертіңіз
JWT_EXPIRES_IN=7d

# Бірнеше порт (үтірмен): Vite 3001 немесе 5173
CORS_ORIGIN=http://localhost:3001,http://localhost:5173

# Docker production: бірінші іске қосу үшін кесте жасау (қалғанда false)
# DB_SYNC_ON_START=true
