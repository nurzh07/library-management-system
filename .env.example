# ============================================
# Backend Environment Variables
# ============================================

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lms_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration (REQUIRED - at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d

# Server Configuration
NODE_ENV=development
PORT=3000

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3001,http://localhost:5173

# Database Sync (set to true for first run to create tables)
DB_SYNC_ON_START=false

# ============================================
# Frontend Environment Variables (Build time)
# ============================================

# API URL for frontend
VITE_API_URL=http://localhost:3000/api

# ============================================
# CI/CD Secrets (GitHub Actions)
# ============================================
# Add these to GitHub Repository Settings → Secrets and variables → Actions
# RENDER_BACKEND_DEPLOY_HOOK=https://api.render.com/deploy/srv-xxxxxxxx
# RENDER_FRONTEND_DEPLOY_HOOK=https://api.render.com/deploy/srv-yyyyyyyy
